{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "Evident Technologies institutional design tokens. Canonical source: evident-technologies/.github/brand.",
  "color": {
    "navy":       { "$value": "#15294C", "$type": "color", "$description": "Deep Navy — primary, authority, wordmark" },
    "blackBlue":  { "$value": "#0A1525", "$type": "color", "$description": "Black-Blue — depth, dark surfaces, body text" },
    "slate":      { "$value": "#5B6573", "$type": "color", "$description": "Slate Gray — secondary text, rules, dividers" },
    "ivory":      { "$value": "#F4EFE3", "$type": "color", "$description": "Constitutional Ivory — ground, paper" },
    "gold":       { "$value": "#BF9F4E", "$type": "color", "$description": "Muted Gold — restrained accent, verification only" }
  },
  "font": {
    "family": {
      "primary":   { "$value": "Inter, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif", "$type": "fontFamily", "$description": "Primary — system / UI / headings" },
      "secondary": { "$value": "'Source Sans 3', 'Source Sans Pro', system-ui, sans-serif", "$type": "fontFamily", "$description": "Secondary — body / long form" }
    },
    "weight": {
      "wordmarkPrimary":   { "$value": 700, "$type": "fontWeight" },
      "wordmarkSecondary": { "$value": 500, "$type": "fontWeight" },
      "heading":           { "$value": 600, "$type": "fontWeight" },
      "body":              { "$value": 400, "$type": "fontWeight" }
    }
  }
}
